# ============================================================
# .gitignore — Files that must NEVER be committed to Git
#
# WHY THIS FILE EXISTS:
# API keys cost money and grant access to paid services.
# If a key leaks into Git history, it's compromised forever —
# even deleting the file later doesn't remove it from history.
# This file tells Git to pretend certain files don't exist.
# ============================================================

# API keys live here — NEVER commit this file.
# The program creates it automatically on first run.
config.properties

# Eclipse project files (each developer's Eclipse generates its own)
.classpath
.project
.settings/

# Compiled bytecode (generated by javac, not source code)
bin/

# OS-generated files
.DS_Store
Thumbs.db
