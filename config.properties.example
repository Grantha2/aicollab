# ============================================================
# config.properties.example — Template for API key configuration
# ============================================================
#
# You DON'T need to copy or edit this file manually.
# Just run the program — it will prompt you for your keys
# on first launch and create config.properties automatically.
#
# This file exists as a reference so you know what keys are
# needed and where to get them.
#
# WHERE TO GET KEYS:
#   Anthropic (Claude): https://console.anthropic.com/settings/keys
#   OpenAI (GPT):       https://platform.openai.com/api-keys
#   Google (Gemini):    https://aistudio.google.com/apikey
#
# NEVER commit config.properties to Git (it's in .gitignore).
# ============================================================

claude.api.key=YOUR_ANTHROPIC_KEY_HERE
openai.api.key=YOUR_OPENAI_KEY_HERE
gemini.api.key=YOUR_GEMINI_KEY_HERE
