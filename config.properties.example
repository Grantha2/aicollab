# config.properties.example — template for API key configuration.
#
# Copy this file to config.properties and fill in your API keys.
# config.properties is gitignored; never commit it.
#
# Where to get keys:
#   Anthropic (Claude): https://console.anthropic.com/settings/keys
#   OpenAI (GPT):       https://platform.openai.com/api-keys
#   Google (Gemini):    https://aistudio.google.com/apikey

claude.key=YOUR_CLAUDE_KEY_HERE
openai.key=YOUR_OPENAI_KEY_HERE
gemini.key=YOUR_GEMINI_KEY_HERE

# Optional overrides; omit to use the defaults baked into Config.java.
# claude.model=claude-opus-4-6
# openai.model=gpt-5.4-mini
# gemini.model=gemini-3.1-pro-preview
# max.response.tokens=8192
# debate.rounds=1
